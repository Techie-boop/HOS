{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hos",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-06-28",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "build": {
    "command": "npx prisma generate && npx opennextjs-cloudflare build"
  }
}
